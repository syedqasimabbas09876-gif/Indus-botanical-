<div id="ai-chat-box" style="display:none; position:fixed; right:25px; bottom:100px; width:320px; background:white; border-radius:15px; box-shadow:0 15px 40px rgba(0,0,0,0.2); index:2000; overflow:hidden; border: 1px solid var(--primary-green); font-family: sans-serif;">
<div style="background: var(--primary-green); color:white; padding:15px; font-weight:bold; display:flex; justify-content:space-between; align-items:center;">
<span><i class="fas fa-robot"></i> Indus AI Assistant</span>
<span onclick="Toggle AI chat()" style="cursor:pointer; font-size:20px;">&times;</span>
</div>
<div id="ai-content" style="padding:15px; height:250px; overflow-y:auto; background:#f9f9f9; font-size:0.9rem; line-height:1.4;">
<div style="background:#eee; padding:10px; border-radius:10px; margin-bottom:10px; color:#444;">
Hello! I am your Indus Botanical export assistant. How can I help you with our organic products today?
</div>
</div>
<div style="padding:10px; border-top:1px solid #eee; background:white; display:flex; flex-wrap:wrap; gap:5px;">
<button onclick="aiProcess('price')" style="background:#f0f4f0; border:1px solid var(--primary-green); padding:5px 10px; border-radius:5px; cursor:pointer; font-size:0.8rem;">Check Rates</button>
<button onclick="aiProcess('sample')" style="background:#f0f4f0; border:1px solid var(--primary-green); padding:5px 10px; border-radius:5px; cursor:pointer; font-size:0.8rem;">Free Sample?</button>
<button onclick="aiProcess('shipping')" style="background:#f0f4f0; border:1px solid var(--primary-green); padding:5px 10px; border-radius:5px; cursor:pointer; font-size:0.8rem;">Delivery Time</button>
</div>
</div>

<div class="sticky-controls">
<a href="https://instagram.com/Indus_botanical" class="icon-btn insta" target="_blank"><i class="fab fa-instagram"></i></a>
<a href="https://wa.me/923299718034" class="icon-btn whatsapp" target="_blank"><i class="fab fa-whatsapp"></i></a>
<a href="javascript:void(0)" class="icon-btn ai pulse-effect" onclick="toggleAIChat()" style="background:#1a1a1a;">
<i class="fas fa-microchip" id="ai-btn-icon"></i>
</a>
</div>

<style>
/* Pulse Effect to make AI look 'Alive' */
.pulse-effect {
animation: ai-glow 2s infinite;
border: 2px solid var(--primary-green);
}
@keyframes ai-glow {
0% { box-shadow: 0 0 0 0 rgba(45, 90, 39, 0.7); }
70% { box-shadow: 0 0 0 15px rgba(45, 90, 39, 0); }
100% { box-shadow: 0 0 0 0 rgba(45, 90, 39, 0); }
}
/* Thinking Dots */
.typing-dot { display:inline-block; width:4px; height:4px; background:#888; border-radius:50%; margin-right:2px; animation: wave 1.3s linear infinite; }
.typing-dot:nth-child(2) { animation-delay: -1.1s; }
.typing-dot:nth-child(3) { animation-delay: -0.9s; }
@keyframes wave { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-4px); } }
</style>

<script>
function toggleAIChat() {
var box = document.getElementById('ai-chat-box');
box.style.display = (box.style.display === 'none') ? 'block' : 'none';
}

function aiProcess(type) {
var content = document.getElementById('ai-content');

// Add User message visual
var userChoice = type === 'price' ? "Check Rates" : (type === 'sample' ? "Free Sample?" : "Delivery Time");
content.innerHTML += `<div style="text-align:right; margin-bottom:10px;"><span style="background:var(--primary-green); color:white; padding:8px 12px; border-radius:10px; display:inline-block;">${userChoice}</span></div>`;

// Add Thinking Animation
var thinkingId = "think-" + Date.now();
content.innerHTML += `<div id="${thinkingId}" style="color:#888; margin-bottom:10px;"><i>AI is analyzing your request</i> <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>`;
content.scrollTop = content.scrollHeight;

// Smart Delay to simulate "Fast Thinking"
setTimeout(function() {
document.getElementById(thinkingId).remove();
var reply = "";

if(type === 'price') {
reply = "<b>Indus AI:</b> Our current wholesale rates are: <br>• Neem Powder: $19.99/KG <br>• Dry Leaves: $14.50/KG <br>Prices are $5 lower than market average.";
} else if(type === 'sample') {
reply = "<b>Indus AI:</b> Yes, we offer 100g free samples for business verification. Note: Shipment charges apply and samples are non-returnable.";
} else if(type === 'shipping') {
reply = "<b>Indus AI:</b> We use DHL & FedEx for global delivery. USA/Europe takes 5-7 business days. Middle East takes 3-4 days.";
}

content.innerHTML += `<div style="background:#eee; padding:10px; border-radius:10px; margin-bottom:10px; color:#333;">${reply}</div>`;
content.scrollTop = content.scrollHeight;
}, 1500);
}
</script>
